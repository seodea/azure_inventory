# ── Backend Environment Variables ──────────────────────────────────────────

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
USE_REDIS=true

# ── Frontend Environment Variables ──────────────────────────────────────────

# API URL (Docker 빌드 시 사용)
VITE_API_URL=https://api.inven.xyz

# 개발 환경
# VITE_API_URL=http://localhost:8000

# CORS (프로덕션)
# CORS_ORIGINS=https://inven.xyz

# 기타 설정
# LOG_LEVEL=info
